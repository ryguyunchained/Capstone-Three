{
  "project": "Predicting Customer Conversion in Digital Marketing",
  "author": "Ryan Lange",
  "dataset": {
    "source": "Kaggle - Predict Conversion in Digital Marketing Dataset (Rabie El Kharoua)",
    "rows": 8000,
    "target": "Conversion",
    "class_balance": {"positive_class_1": "88%", "negative_class_0": "12%"},
    "train_test_split": {"test_size": 0.2, "random_state": 42, "stratify": true, "test_rows": 1600}
  },
  "class_imbalance_handling": {
    "methods_compared": ["class_weight=balanced", "SMOTE oversampling"],
    "smote_before": {"class_1": 5610, "class_0": 790},
    "smote_after": {"class_1": 5610, "class_0": 5610},
    "conclusion": "Marginal difference between class weighting and SMOTE; both retained for comparison."
  },
  "models": [
    {
      "name": "Logistic Regression (EDA baseline, unweighted)",
      "roc_auc": 0.782,
      "accuracy": 0.75,
      "class_0": {"precision": 0.30, "recall": 0.73, "f1": 0.42, "support": 198},
      "class_1": {"precision": 0.95, "recall": 0.76, "f1": 0.84, "support": 1402}
    },
    {
      "name": "Logistic Regression (class_weight=balanced)",
      "roc_auc": 0.783268,
      "accuracy": 0.75,
      "class_0": {"precision": 0.30, "recall": 0.74, "f1": 0.42, "support": 198},
      "class_1": {"precision": 0.95, "recall": 0.75, "f1": 0.84, "support": 1402}
    },
    {
      "name": "Logistic Regression (SMOTE, default 0.5 threshold)",
      "roc_auc": 0.779640,
      "accuracy": 0.76,
      "class_0": {"precision": 0.31, "recall": 0.72, "f1": 0.43, "support": 198},
      "class_1": {"precision": 0.95, "recall": 0.77, "f1": 0.85, "support": 1402}
    },
    {
      "name": "Logistic Regression (SMOTE, tuned threshold=0.70 on class 0)",
      "roc_auc": null,
      "accuracy": 0.86,
      "class_0": {"precision": 0.43, "recall": 0.42, "f1": 0.42, "support": 198},
      "class_1": {"precision": 0.92, "recall": 0.92, "f1": 0.92, "support": 1402},
      "note": "Threshold selected from precision/recall crossover point on the PR curve"
    },
    {
      "name": "Gradient Boosting (SMOTE)",
      "roc_auc": 0.789244,
      "accuracy": 0.89,
      "class_0": {"precision": 0.54, "recall": 0.49, "f1": 0.52, "support": 198},
      "class_1": {"precision": 0.93, "recall": 0.94, "f1": 0.94, "support": 1402},
      "selected_as_best_model": true
    },
    {
      "name": "SVM - RBF kernel (SMOTE)",
      "roc_auc": 0.726136,
      "accuracy": 0.83,
      "class_0": {"precision": 0.36, "recall": 0.44, "f1": 0.40, "support": 198},
      "class_1": {"precision": 0.92, "recall": 0.89, "f1": 0.90, "support": 1402}
    }
  ],
  "top_features_baseline_logreg_coefficients": [
    {"feature": "ClickThroughRate", "coefficient": 0.450161},
    {"feature": "TimeOnSite", "coefficient": 0.437125},
    {"feature": "EmailClicks", "coefficient": 0.415597},
    {"feature": "AdSpend", "coefficient": 0.384415},
    {"feature": "EmailOpens", "coefficient": 0.381409},
    {"feature": "LoyaltyPoints", "coefficient": 0.364736},
    {"feature": "PreviousPurchases", "coefficient": 0.361701},
    {"feature": "CampaignType_Conversion", "coefficient": 0.322700},
    {"feature": "PagesPerVisit", "coefficient": 0.293841},
    {"feature": "ConversionRate", "coefficient": 0.265498}
  ],
  "engineered_features": ["ClickToOpenRatio", "EngagementPerVisit", "AdSpendPerClick", "EngagementScore", "AgeGroup (binned)"],
  "conclusion": "Gradient Boosting on SMOTE-balanced data was the strongest performer (ROC-AUC 0.789, class-0 F1 0.52), though gains over the weighted logistic regression baseline were modest. Given the dataset's heavy class imbalance (88% positive) and weak underlying feature correlations, this is likely close to the ceiling for this dataset without additional features or a larger non-converter sample."
}
